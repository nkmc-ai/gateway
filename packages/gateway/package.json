{
  "name": "@nkmc/gateway",
  "version": "0.1.3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js",
      "require": "./dist/http.cjs"
    },
    "./proxy": {
      "types": "./dist/proxy.d.ts",
      "import": "./dist/proxy.js",
      "require": "./dist/proxy.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@nkmc/agent-fs": "workspace:*",
    "@nkmc/core": "^0.1.1",
    "hono": "^4.11.9",
    "jose": "^6.1.3",
    "nanoid": "^5.1.5",
    "stripe": "^20.3.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nkmc-ai/gateway"
  },
  "description": "The gateway of internet for all agents — nkmc gateway"
}
